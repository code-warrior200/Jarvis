# JARVIS Application Configuration
# Copy this file to .env and update values as needed

# Application Settings
JARVIS_DEBUG=False
JARVIS_LOG_LEVEL=INFO
JARVIS_VOICE_LANG=en-US
JARVIS_VOICE_RATE=150

# Audio Settings
JARVIS_MICROPHONE_INDEX=0
JARVIS_LISTEN_TIMEOUT=10
JARVIS_PHRASE_TIME_LIMIT=None

# GUI Settings
JARVIS_GUI_THEME=dark
JARVIS_GUI_WINDOW_WIDTH=1000
JARVIS_GUI_WINDOW_HEIGHT=700

# Data Directories
JARVIS_DATA_DIR=./data
JARVIS_LOG_DIR=./logs
JARVIS_CONFIG_DIR=./config

# API Keys (if needed for future features)
# OPENAI_API_KEY=your_key_here
# WEATHER_API_KEY=your_key_here

# System Commands
JARVIS_ENABLE_SYSTEM_COMMANDS=True
JARVIS_ENABLE_WINDOW_MANAGEMENT=True

# Feature Flags
JARVIS_FEATURE_VOICE=True
JARVIS_FEATURE_TEXT=True
JARVIS_FEATURE_APP_CONTROL=True
